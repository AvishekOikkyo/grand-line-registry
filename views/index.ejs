<!DOCTYPE html>
<html data-theme="light">

<head>
  <meta charset="UTF-8">
  <title>Grand Line Registry</title>
  <link rel="stylesheet" href="/css/main.css">
</head>

<body class="p-6">

  <!-- Navbar -->
  <%- include("partials/navbar", { title: "The Crew" }) %>

  <!-- Page Heading -->
  <div class="text-center mb-10">
    <h1 class="text-4xl font-bold">The Straw Hat Pirates</h1>
    <p class="text-lg mt-2">
      Meet the legendary crew sailing across the Grand Line.
    </p>
  </div>

  <!-- Crew Cards Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    <% for (const member of crew) { %>

      <div class="card bg-base-100 shadow-xl">

        <div class="card-body">

          <h2 class="card-title"><%= member.name %></h2>

          <p><strong>Role:</strong> <%= member.role %></p>

          <p><strong>Devil Fruit:</strong> <%= member.devilFruit %></p>

          <p>
            <strong>Bounty:</strong>
            <%= member.bounty.toLocaleString() %> Berries
          </p>

          <!-- Status Badge -->
          <% if (member.status === "active") { %>

            <span class="badge badge-success">Active</span>

          <% } else if (member.status === "pending") { %>

            <span class="badge badge-warning">Pending Approval</span>

          <% } else { %>

            <span class="badge badge-error">Bounty Frozen</span>

          <% } %>

          <!-- Button -->
          <div class="card-actions justify-end mt-4">
            <a href="/crew" class="btn btn-primary">
              View All Crew
            </a>
          </div>

        </div>

      </div>

    <% } %>

  </div>

</body>

</html>